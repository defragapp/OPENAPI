{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sovereign-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_ENV": "development",
    "APP_VERSION": "0.0.1",
    "AI_PROVIDER": "cloudflare-gateway",
    "AI_MODEL": "openai/gpt-5.6-terra",
    "AI_GATEWAY_ID": "sovereign"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sovereign-os",
      "database_id": "REPLACE_IN_CLOUDFLARE"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "THREADS",
        "class_name": "ThreadCoordinator"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "ThreadCoordinator"
      ]
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/health",
      "/healthz",
      "/ready"
    ]
  },
  "env": {
    "preview": {
      "name": "sovereign-openapi-preview",
      "compatibility_date": "2026-07-20",
      "compatibility_flags": [
        "nodejs_compat"
      ],
      "observability": {
        "enabled": true
      },
      "vars": {
        "APP_ENV": "preview",
        "APP_VERSION": "0.0.1-preview",
        "AI_PROVIDER": "cloudflare-gateway",
        "AI_MODEL": "openai/gpt-5.6-terra",
        "AI_GATEWAY_ID": "sovereign",
        "SOVV_INTERNAL_BASE_URL": "",
        "STRIPE_SUCCESS_URL": "https://sovereign-openapi-preview.workers.dev/you?billing=success",
        "STRIPE_CANCEL_URL": "https://sovereign-openapi-preview.workers.dev/you?billing=cancelled",
        "STRIPE_PORTAL_RETURN_URL": "https://sovereign-openapi-preview.workers.dev/you?billing=portal",
        "SCRIPTURE_TRANSLATION": "WEB"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "sovereign-openapi-preview-db",
          "database_id": "REPLACE_WITH_PREVIEW_D1_DATABASE_ID"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "THREADS",
            "class_name": "ThreadCoordinator"
          }
        ]
      },
      "migrations": [
        {
          "tag": "preview-v1",
          "new_sqlite_classes": [
            "ThreadCoordinator"
          ]
        }
      ],
      "ai": {
        "binding": "AI"
      },
      "assets": {
        "directory": "../web/dist",
        "binding": "ASSETS",
        "not_found_handling": "single-page-application",
        "run_worker_first": [
          "/api/*",
          "/health",
          "/healthz",
          "/ready"
        ]
      },
      "r2_buckets": [
        {
          "binding": "ARTIFACTS",
          "bucket_name": "sovereign-openapi-preview-artifacts"
        }
      ],
      "queues": {
        "producers": [
          {
            "binding": "JOBS",
            "queue": "sovereign-openapi-preview-jobs"
          }
        ],
        "consumers": [
          {
            "queue": "sovereign-openapi-preview-jobs",
            "max_batch_size": 10,
            "max_batch_timeout": 30
          }
        ]
      },
      "triggers": {
        "crons": [
          "*/15 * * * *"
        ]
      },
      "services": [
        {
          "binding": "BASELINE",
          "service": "sovereign-baseline-preview",
          "entrypoint": "BaselineEntrypoint"
        }
      ]
    }
  },
  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "sovereign-openapi-artifacts"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "JOBS",
        "queue": "sovereign-openapi-jobs"
      }
    ],
    "consumers": [
      {
        "queue": "sovereign-openapi-jobs",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      }
    ]
  },
  "triggers": {
    "crons": [
      "*/15 * * * *"
    ]
  },
  "services": [
    {
      "binding": "BASELINE",
      "service": "sovereign-baseline",
      "entrypoint": "BaselineEntrypoint"
    }
  ]
}
