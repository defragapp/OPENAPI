{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sovereign-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_ENV": "development",
    "APP_VERSION": "0.0.1",
    "AI_PROVIDER": "cloudflare-gateway",
    "AI_MODEL": "openai/gpt-5.6-terra",
    "AI_GATEWAY_ID": "sovereign"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sovereign-os",
      "database_id": "REPLACE_IN_CLOUDFLARE"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "THREADS",
        "class_name": "ThreadCoordinator"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "ThreadCoordinator"
      ]
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "sovereign-os-artifacts"
    }
  ],
  "services": [
    {
      "binding": "BASELINE",
      "service": "sovereign-baseline"
    }
  ],
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/health",
      "/healthz",
      "/ready"
    ]
  },
  "env": {
    "preview": {
      "name": "sovereign-openapi-preview",
      "compatibility_date": "2026-07-20",
      "compatibility_flags": [
        "nodejs_compat"
      ],
      "observability": {
        "enabled": true
      },
      "vars": {
        "APP_ENV": "preview",
        "APP_VERSION": "0.0.1-preview",
        "AI_PROVIDER": "cloudflare-gateway",
        "AI_MODEL": "openai/gpt-5.6-terra",
        "AI_GATEWAY_ID": "sovereign",
        "SOVV_INTERNAL_BASE_URL": "",
        "STRIPE_SUCCESS_URL": "https://sovereign-openapi-preview.workers.dev/you?billing=success",
        "STRIPE_CANCEL_URL": "https://sovereign-openapi-preview.workers.dev/you?billing=cancelled",
        "STRIPE_PORTAL_RETURN_URL": "https://sovereign-openapi-preview.workers.dev/you?billing=portal",
        "STRIPE_PRICE_SOVEREIGN_PLUS": "price_test_sovereign_plus",
        "STRIPE_PRICE_SOVEREIGN_PLUS_MONTHLY": "price_test_sovereign_plus_monthly",
        "STRIPE_PRICE_SOVEREIGN_PLUS_ANNUAL": "price_test_sovereign_plus_annual",
        "STRIPE_PRICE_SOVEREIGN_SUPPORT": "price_test_support",
        "STRIPE_SUPPORT_URL": "",
        "SCRIPTURE_TRANSLATION": "WEB",
        "TERMS_VERSION": "2026-07-21",
        "PRIVACY_VERSION": "2026-07-21"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "sovereign-openapi-preview-db",
          "database_id": "REPLACE_WITH_PREVIEW_D1_DATABASE_ID"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "THREADS",
            "class_name": "ThreadCoordinator"
          }
        ]
      },
      "migrations": [
        {
          "tag": "preview-v1",
          "new_sqlite_classes": [
            "ThreadCoordinator"
          ]
        }
      ],
      "ai": {
        "binding": "AI"
      },
      "r2_buckets": [
        {
          "binding": "ARTIFACTS",
          "bucket_name": "sovereign-openapi-preview-artifacts"
        }
      ],
      "services": [
        {
          "binding": "BASELINE",
          "service": "sovereign-baseline-preview"
        }
      ],
      "assets": {
        "directory": "../web/dist",
        "binding": "ASSETS",
        "not_found_handling": "single-page-application",
        "run_worker_first": [
          "/api/*",
          "/health",
          "/healthz",
          "/ready"
        ]
      }
    }
  }
}
