{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sovereign-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_ENV": "development",
    "APP_VERSION": "0.0.1",
    "AI_PROVIDER": "cloudflare-gateway",
    "AI_MODEL": "openai/gpt-5.6-terra",
    "AI_GATEWAY_ID": "sovereign"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sovereign-os",
      "database_id": "REPLACE_IN_CLOUDFLARE"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "THREADS",
        "class_name": "ThreadCoordinator"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "ThreadCoordinator"
      ]
    }
  ],
  "ai": {
    "binding": "AI"
  }
}
