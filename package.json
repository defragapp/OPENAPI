{
  "name": "sovereign-os",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify:foundation": "node scripts/verify-foundation.mjs",
    "verify:migrations": "node scripts/validate-migrations.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "smoke:openai": "tsx scripts/openai-smoke.ts",
    "smoke:sovereign": "tsx scripts/sovereign-smoke.ts",
    "smoke:gateway": "tsx scripts/cloudflare-gateway-smoke.ts",
    "smoke:worker-gateway": "tsx scripts/worker-gateway-smoke.ts",
    "smoke:stripe": "tsx scripts/stripe-smoke.ts",
    "smoke:product": "tsx scripts/product-smoke.ts",
    "build:preview": "node scripts/build-preview.mjs",
    "preview:bootstrap": "node scripts/cloudflare-preview-bootstrap.mjs",
    "smoke:preview": "tsx scripts/preview-smoke.ts",
    "preview:session": "tsx scripts/create-preview-session.ts"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "tsx": "4.23.1",
    "typescript": "5.8.3",
    "vitest": "4.1.10"
  }
}
