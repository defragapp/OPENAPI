# Documentation only. Use Cloudflare Worker secrets/bindings in production.
AI_PROVIDER=cloudflare-gateway
AI_GATEWAY_ID=sovereign
AI_MODEL=openai/gpt-5.6-terra
CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN is only for GitHub Actions REST smoke verification; production Workers should prefer the AI binding.
# OPENAI_API_KEY is local-development only for AI_PROVIDER=openai-direct. Do not use it for production user traffic.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=
SCRIPTURE_TRANSLATION=WEB
SOVV_INTERNAL_BASE_URL=
SOVV_INTERNAL_AUTH_TOKEN=
BASELINE_INTERNAL_TOKEN=
# Preview deployment variables (non-secret; configure in GitHub Actions variables)
PREVIEW_WORKER_NAME=sovereign-openapi-preview
PREVIEW_BASELINE_WORKER_NAME=sovereign-baseline-preview
PREVIEW_D1_NAME=sovereign-openapi-preview-db
PREVIEW_R2_NAME=sovereign-openapi-preview-artifacts
PREVIEW_BASE_URL=
# PREVIEW_SESSION_SIGNING_SECRET is a secret; do not commit a value.
STRIPE_PRICE_SOVEREIGN_PLUS=price_test_sovereign_plus
STRIPE_PRICE_SOVEREIGN_PLUS_MONTHLY=price_test_sovereign_plus_monthly
STRIPE_PRICE_SOVEREIGN_PLUS_ANNUAL=price_test_sovereign_plus_annual
STRIPE_PRICE_SOVEREIGN_SUPPORT=price_test_support
STRIPE_SUPPORT_URL=
VITE_STRIPE_SUPPORT_URL=
TURNSTILE_SECRET_KEY=
CLOUDFLARE_EMAIL_FROM=
TERMS_VERSION=2026-07-21
PRIVACY_VERSION=2026-07-21
